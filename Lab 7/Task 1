class Calculator {
    public int add(int a, int b) {
        return a + b;
    }
    public double add(double a, double b) {
        return a + b;
    }
    public int add(int a, int b, int c) {
        return a + b + c;
    }
}

public class Main {
    public static void main(String[] args) {
        Calculator calc = new Calculator();
        System.out.println("=== Calculator (Method Overloading) ===");
        int intSum2 = calc.add(10, 20);
        System.out.println("Sum of two integers: " + intSum2);
        double doubleSum = calc.add(10.5, 20.3);
        System.out.println("Sum of two double numbers: " + doubleSum);
        int intSum3 = calc.add(5, 15, 25);
        System.out.println("Sum of three integers: " + intSum3);
    }
}
